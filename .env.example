# ============================================================
# API Key 配置文件
# 复制此文件为 .env 并填入你的真实 Key
#   cp .env.example .env
# ============================================================

# DeepSeek API Key（对话模型）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 阿里云 DashScope API Key（文本嵌入模型，用于长期记忆搜索）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 高德地图 API Key（Web 服务类型，用于天气和地点查询）
# 获取地址：https://console.amap.com/
AMAP_API_KEY=your-amap-key-here

# ============================================================
# 以下为可选配置（均有默认值，不需要改）
# ============================================================
# GAODE_API_KEY=              # 高德 API Key 的别名（和 AMAP_API_KEY 二选一）
# MEMORY_SHORT_TERM_WINDOW=8  # 保留最近几条消息
# MEMORY_SUMMARY_TRIGGER_MESSAGES=12  # 超过多少条触发摘要压缩
# MEMORY_MAX_SUMMARY_CHARS=1200       # 摘要最大字符数
# LONG_TERM_MEMORY_TOP_K=3            # 长期记忆每次召回几条
